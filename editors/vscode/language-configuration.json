{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "{",
      "close": "}"
    },
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "\"",
      "close": "\"",
      "notIn": [
        "string",
        "comment"
      ]
    },
    {
      "open": "'",
      "close": "'",
      "notIn": [
        "string",
        "comment"
      ]
    }
  ],
  "surroundingPairs": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ],
    [
      "\"",
      "\""
    ],
    [
      "'",
      "'"
    ]
  ],
  "wordPattern": "(@[A-Za-z_][A-Za-z0-9_-]*|![A-Za-z_][A-Za-z0-9_-]*|\\?[A-Za-z_][A-Za-z0-9_-]*|\\*[A-Za-z_][A-Za-z0-9_-]*|\\$\\{[^}]*\\}|[A-Za-z_][A-Za-z0-9_.-]*)",
  "indentationRules": {
    "increaseIndentPattern": "^((?!#).)*(?::\\s*(?:#.*)?$|[|>]\\s*(?:#.*)?$|\\{\\s*(?:#.*)?$|\\[\\s*(?:#.*)?$)",
    "decreaseIndentPattern": "^\\s*[\\]}]|^\\s*\\.\\.\\.\\s*$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*[^#\\n]+:\\s*[|>]\\s*$",
      "action": {
        "indent": "indent"
      }
    }
  ]
}
